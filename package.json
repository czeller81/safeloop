{
  "name": "safeloop",
  "version": "0.6.0",
  "description": "Safeloop v0.6.0 is a lightweight Agent Accountability + Handoff SDK for local AI agent loops with Case Files, attachments, participants, handoff manifests, query reports, and an agent adapter protocol.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/czeller81/safeloop"
  },
  "bugs": {
    "url": "https://github.com/czeller81/safeloop/issues"
  },
  "homepage": "https://github.com/czeller81/safeloop#readme",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --config jest.config.js",
    "example": "ts-node examples/wrap-agent.ts",
    "example:live-simulation": "ts-node examples/breaker-live-simulation.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "governance",
    "accountability",
    "handoff",
    "workflow",
    "audit",
    "safety",
    "typescript"
